%%   "AIPS"(clinical PHI source), "TIC/Cacheware" C++ pipeline, "Hetzner".

flowchart TB
  %% ===== READINESS HEAT-MAP LEGEND =====
  subgraph LEGEND["READINESS HEAT-MAP  ·  diamond = open decision"]
    direction LR
    L1["In place / operational"]:::ready
    L2["In progress / building"]:::building
    L3["Planned / not started"]:::planned
    L4["Gap / at risk"]:::gap
    L5{"Open decision"}:::decision
  end

  %% ===== ACCESS & IDENTITY (gates everything) =====
  subgraph ACCESS["ACCESS &amp; IDENTITY  (gates the whole environment)"]
    direction LR
    JC["JumpCloud — SSO / Identity<br/>audit maps: agent · person · process"]:::building
    TS["Tailscale — zero-trust tunnel<br/>tailnet-only; no open SSH/console"]:::ready
  end

  %% ===== 1. SOURCES / SYSTEM OF RECORD =====
  subgraph SRC["1 · SOURCES &amp; SYSTEM OF RECORD  (business data)"]
    direction LR
    ERP["ERPNext<br/>Ops · Financials · AP/AR"]:::building
    RT["Rethink<br/>clinical operations"]:::ready
    QB["QuickBooks<br/>legacy financials"]:::ready
    EM["Inbound Email &amp; Docs<br/>invoices · parent emails"]:::building
  end

  %% ===== 2. SENSITIVE / PHI ZONE =====
  subgraph PHI["2 · SENSITIVE / PHI ZONE  (segmented · HIPAA)"]
    direction LR
    AIPS["AIPS — Clinical PHI store<br/>patient &amp; parent records<br/>(kept separate; Azure candidate)"]:::building
  end

  %% ===== 3. ANONYMIZATION — AIR-GAP DMZ =====
  subgraph DMZ["3 · ANONYMIZATION — AIR-GAP DMZ  (HIPAA boundary · VLAN30 DMZ / VLAN20 AI)"]
    direction LR
    OC["OpenClaw — execution layer<br/>de-identify · sanitize · scoped data"]:::building
    HM["Hermes — orchestration layer<br/>metadata-only routing"]:::building
  end

  %% ===== 4. DATA PIPELINE & WAREHOUSE =====
  subgraph PIPE["4 · DATA PIPELINE &amp; WAREHOUSE"]
    direction LR
    HASH["Raw hash / parse<br/>TIC (Cacheware) C++ pipeline"]:::ready
    PKG["Packaging<br/>de-identified, anonymized sets"]:::building
    DW{"Data Warehouse<br/>HOST TBD ★ (Hetzner vs Azure vs AWS)"}:::decision
  end

  %% ===== 5. INTELLIGENCE LAYER =====
  subgraph INT["5 · INTELLIGENCE LAYER"]
    direction LR
    AN["Analysis &amp; Agents<br/>inference · automation"]:::building
    LOC["Local inference<br/>Ollama on local box"]:::planned
    CLD["Cloud LLM escalation<br/>Anthropic / OpenAI"]:::planned
  end

  %% ===== 6. BUSINESS INTELLIGENCE =====
  subgraph BI["6 · BUSINESS INTELLIGENCE / REPORTING"]
    direction LR
    MB["Metabase<br/>dashboards · MCP · CLI"]:::ready
    INS["ERPNext Insights<br/>candidate BI tool"]:::planned
  end

  %% ===== INTERNAL COLLABORATION — CONTROL PLANES =====
  subgraph COLLAB["INTERNAL COLLABORATION — CONTROL PLANES  (keep AI &amp; human work separate → no schema corruption)"]
    direction LR
    PLANE["Plane — HUMAN control plane<br/>PM · tasks · curated, finished work"]:::building
    AF["AppFlowy — AI / AGENT control plane<br/>agent-driven work (e.g. clause version-control)"]:::planned
    AFFINE["Affine — INTAKE / sandbox<br/>unstructured, in-progress (replaces Obsidian/OneNote/Whiteboard)"]:::planned
  end

  %% ===== INFRASTRUCTURE / HOSTING (reference band) =====
  subgraph HOST["INFRASTRUCTURE / HOSTING  (current → target; see open decisions)"]
    direction LR
    HZ["Hetzner — build/test/own-built<br/>ERPNext + internal stack (today)"]:::ready
    AZ{"Azure — HIPAA / BAA out-of-box<br/>sensitive data + warehouse candidate"}:::decision
    AWSN["AWS — TIC pipeline / processing<br/>(BYO models, cheaper compute)"]:::ready
    LOCAL{"Hybrid local box — inference<br/>data sovereignty vs ops overhead"}:::decision
    GG["Google → M365 — Veronica's tools<br/>migration in flight"]:::building
  end

  %% ===== DEVSECOPS / SRE OVERLAY =====
  subgraph SECOPS["DevSecOps / SRE OVERLAY  (compliance · audit · reliability — spans all)"]
    direction LR
    KUMA["Monitoring (Uptime Kuma) · Backups<br/>Caddy→NGINX reverse proxy"]:::ready
    DSO["DevSecOps / SRE owner — TO HIRE<br/>HIPAA audit + reliability = full-time job"]:::gap
  end

  %% ===== FLOWS =====
  JC --> TS
  TS ==> ERP
  TS ==> AIPS
  QB --> ERP
  RT ==> AIPS
  EM ==> OC
  AIPS ==> OC
  OC ==> HM
  HM ==> HASH
  HASH ==> PKG
  PKG ==> DW
  ERP ==> DW
  DW ==> AN
  DW ==> MB
  DW ==> INS
  AN --> LOC
  LOC -.->|escalate de-identified prompt| CLD
  AN ==> MB
  PLANE -.->|curate / consume| DW
  AF -.->|agents| AN

