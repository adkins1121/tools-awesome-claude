  linkStyle 4,5,6,7,8,9,10 stroke:#C00000,stroke-width:2.5px;
  linkStyle 16 stroke:#2E75B6,stroke-width:1.5px,stroke-dasharray:4 4;
  linkStyle 18,19 stroke:#808080,stroke-width:1.5px,stroke-dasharray:5 5;

